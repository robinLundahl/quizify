generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  CANCELLED
}

enum Currency {
  USD
  SEK
  EUR
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  SUSPENDED
}

enum PayoutStatus {
  PENDING
  RELEASED
  FAILED
}

enum NotificationType {
  PURCHASE
  RENTAL_STARTED
  RENTAL_EXPIRING
  PAYOUT_RELEASED
  NEW_REVIEW
  DISCOUNT_OFFER
  LISTING_STATUS_CHANGED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  avatar        String?
  provider      String
  passwordHash  String?
  plan          Plan     @default(FREE)
  isAdmin       Boolean  @default(false)
  emailVerified              Boolean  @default(false)
  aiGenerationsUsedThisMonth Int      @default(0)
  aiGenerationsResetAt       DateTime @default(now())
  createdAt                  DateTime           @default(now())
  bio                        String?
  stripeAccountId            String?
  stripeCustomerId           String?
  stripeSubscriptionId       String?
  subscriptionStatus         SubscriptionStatus @default(FREE)
  trialEndsAt                DateTime?

  quizzes           Quiz[]
  participants      Participant[]
  hostedSessions    GameSession[]
  emailVerification EmailVerification?
  listings          MarketplaceListing[]
  purchases         QuizPurchase[]
  rentals           QuizRental[]
  payouts           CreatorPayout[]
  discountOffers    DiscountOffer[]
  notifications     Notification[]
  listingReports    ListingReport[]
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Quiz & Questions ─────────────────────────────────────────────────────────

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String?
  language    String?
  difficulty  String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions Question[]
  sessions  GameSession[]
  listings  MarketplaceListing[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  OPEN_ENDED
  IMAGE
  MAP
  RANKING
  AUDIO
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  type      QuestionType
  text      String
  imageUrl       String?
  correctAnswers String[]
  translations   Json?
  order          Int
  timeLimit      Int          @default(20)
  useTimer       Boolean      @default(true)
  points         Int          @default(1000)

  quiz          Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answerOptions AnswerOption[]
  mapQuestion   MapQuestion?
  audioQuestion AudioQuestion?
  rankingItems  RankingItem[]
  gameAnswers   GameAnswer[]

  @@index([quizId, order])
}

model AnswerOption {
  id           String  @id @default(cuid())
  questionId   String
  text         String
  isCorrect    Boolean
  translations Json?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model MapQuestion {
  id         String @id @default(cuid())
  questionId String @unique
  lat        Float
  lng        Float

  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  rings     MapRing[]
}

model MapRing {
  id            String      @id @default(cuid())
  mapQuestionId String
  radiusKm      Float
  points        Int
  order         Int

  mapQuestion MapQuestion @relation(fields: [mapQuestionId], references: [id], onDelete: Cascade)

  @@index([mapQuestionId, order])
}

model AudioQuestion {
  id         String   @id @default(cuid())
  questionId String   @unique
  url        String
  platform   String
  embedUrl   String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model RankingItem {
  id              String @id @default(cuid())
  questionId      String
  label           String
  correctPosition Int
  order           Int
  translations    Json?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, correctPosition])
}

// ─── Game Sessions ────────────────────────────────────────────────────────────

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

model GameSession {
  id         String        @id @default(cuid())
  quizId     String
  hostId     String
  code       String        @unique
  status     SessionStatus @default(WAITING)
  createdAt  DateTime      @default(now())
  finishedAt DateTime?

  quiz         Quiz          @relation(fields: [quizId], references: [id])
  host         User          @relation(fields: [hostId], references: [id])
  participants Participant[]
}

model Participant {
  id        String @id @default(cuid())
  sessionId String
  userId    String?
  nickname  String
  score     Int    @default(0)

  session     GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id])
  gameAnswers GameAnswer[]

  @@index([sessionId])
}

model GameAnswer {
  id            String  @id @default(cuid())
  participantId String
  questionId    String
  answer        String
  pointsEarned  Int     @default(0)
  responseTimeMs Int

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([participantId, questionId])
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

model MarketplaceListing {
  id               String        @id @default(cuid())
  quizId           String
  creatorId        String
  price            Int
  currency         Currency
  rentalPrice      Int?
  status           ListingStatus @default(DRAFT)
  listingScore     Float         @default(0)
  versionAtPublish Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  quiz           Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  creator        User            @relation(fields: [creatorId], references: [id])
  purchases      QuizPurchase[]
  rentals        QuizRental[]
  discountOffers DiscountOffer[]
  reports        ListingReport[]
}

model QuizPurchase {
  id                String   @id @default(cuid())
  buyerId           String
  listingId         String
  purchaseDate      DateTime @default(now())
  amountPaid        Int
  versionAtPurchase Int

  buyer   User               @relation(fields: [buyerId], references: [id])
  listing MarketplaceListing @relation(fields: [listingId], references: [id])
  review  MarketplaceReview?
}

model QuizRental {
  id         String   @id @default(cuid())
  userId     String
  listingId  String
  rentedAt   DateTime @default(now())
  expiresAt  DateTime
  amountPaid Int

  user    User               @relation(fields: [userId], references: [id])
  listing MarketplaceListing @relation(fields: [listingId], references: [id])
}

model CreatorPayout {
  id               String       @id @default(cuid())
  creatorId        String
  amount           Int
  currency         Currency
  status           PayoutStatus @default(PENDING)
  stripeTransferId String
  releasesAt       DateTime
  receiptUrl       String?
  createdAt        DateTime     @default(now())

  creator User @relation(fields: [creatorId], references: [id])
}

model MarketplaceReview {
  id         String   @id @default(cuid())
  purchaseId String   @unique
  rating     Int
  body       String?
  createdAt  DateTime @default(now())

  purchase QuizPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
}

model DiscountOffer {
  id          String    @id @default(cuid())
  userId      String
  listingId   String
  discountPct Int
  validUntil  DateTime
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())

  user    User               @relation(fields: [userId], references: [id])
  listing MarketplaceListing @relation(fields: [listingId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ListingReport {
  id               String    @id @default(cuid())
  listingId        String
  reportedByUserId String?
  reason           String
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  listing    MarketplaceListing @relation(fields: [listingId], references: [id])
  reportedBy User?              @relation(fields: [reportedByUserId], references: [id])
}
