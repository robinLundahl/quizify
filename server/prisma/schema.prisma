generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  avatar        String?
  provider      String
  passwordHash  String?
  plan          Plan     @default(FREE)
  isAdmin       Boolean  @default(false)
  emailVerified              Boolean  @default(false)
  aiGenerationsUsedThisMonth Int      @default(0)
  aiGenerationsResetAt       DateTime @default(now())
  createdAt                  DateTime @default(now())

  quizzes           Quiz[]
  participants      Participant[]
  hostedSessions    GameSession[]
  emailVerification EmailVerification?
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Quiz & Questions ─────────────────────────────────────────────────────────

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions Question[]
  sessions  GameSession[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  OPEN_ENDED
  IMAGE
  MAP
  RANKING
  AUDIO
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  type      QuestionType
  text      String
  imageUrl       String?
  correctAnswers String[]
  translations   Json?
  order          Int
  timeLimit      Int          @default(20)
  useTimer       Boolean      @default(true)
  points         Int          @default(1000)

  quiz          Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answerOptions AnswerOption[]
  mapQuestion   MapQuestion?
  audioQuestion AudioQuestion?
  rankingItems  RankingItem[]
  gameAnswers   GameAnswer[]

  @@index([quizId, order])
}

model AnswerOption {
  id           String  @id @default(cuid())
  questionId   String
  text         String
  isCorrect    Boolean
  translations Json?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model MapQuestion {
  id         String @id @default(cuid())
  questionId String @unique
  lat        Float
  lng        Float

  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  rings     MapRing[]
}

model MapRing {
  id            String      @id @default(cuid())
  mapQuestionId String
  radiusKm      Float
  points        Int
  order         Int

  mapQuestion MapQuestion @relation(fields: [mapQuestionId], references: [id], onDelete: Cascade)

  @@index([mapQuestionId, order])
}

model AudioQuestion {
  id         String   @id @default(cuid())
  questionId String   @unique
  url        String
  platform   String
  embedUrl   String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model RankingItem {
  id              String @id @default(cuid())
  questionId      String
  label           String
  correctPosition Int
  order           Int
  translations    Json?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, correctPosition])
}

// ─── Game Sessions ────────────────────────────────────────────────────────────

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

model GameSession {
  id         String        @id @default(cuid())
  quizId     String
  hostId     String
  code       String        @unique
  status     SessionStatus @default(WAITING)
  createdAt  DateTime      @default(now())
  finishedAt DateTime?

  quiz         Quiz          @relation(fields: [quizId], references: [id])
  host         User          @relation(fields: [hostId], references: [id])
  participants Participant[]
}

model Participant {
  id        String @id @default(cuid())
  sessionId String
  userId    String?
  nickname  String
  score     Int    @default(0)

  session     GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id])
  gameAnswers GameAnswer[]

  @@index([sessionId])
}

model GameAnswer {
  id            String  @id @default(cuid())
  participantId String
  questionId    String
  answer        String
  pointsEarned  Int     @default(0)
  responseTimeMs Int

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([participantId, questionId])
}
