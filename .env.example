# Database (Supabase — pooled connection for runtime, direct for migrations)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth
# JWT: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ANTHROPIC_API_KEY=

# Stripe — https://dashboard.stripe.com (test keys)
# See backlog/TICKET-051.md for full setup instructions
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# Email — https://resend.com
# See backlog/TICKET-053.md for full setup instructions
# For development, FROM_EMAIL can be onboarding@resend.dev (sends to your own address only)
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev
